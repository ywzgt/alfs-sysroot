mkdir -p -- /lfs_build/tools/i686-lfs-linux-gnu/bin
for i in nm-new strip-new ar ranlib dlltool objdump objcopy readelf; do \
  if [ -f $i ]; then \
    j=`echo $i | sed -e 's/-new//'`; \
    k=`echo $j | sed 's&^&i686-lfs-linux-gnu-&'`; \
    if [ "/lfs_build/tools/bin/$k" != "/lfs_build/tools/i686-lfs-linux-gnu/bin/$j" ]; then \
      rm -f /lfs_build/tools/i686-lfs-linux-gnu/bin/$j; \
      ln /lfs_build/tools/bin/$k /lfs_build/tools/i686-lfs-linux-gnu/bin/$j >/dev/null 2>/dev/null \
	||  /bin/sh ./libtool --mode=install /usr/bin/install -c $i /lfs_build/tools/i686-lfs-linux-gnu/bin/$j; \
    fi; \
  else true; \
  fi; \
done
