libtooldir=`/bin/sh ./libtool --config | /usr/bin/sed -n -e 's/^objdir=//p'`; \
if [ -f $libtooldir/libbfd.a ]; then \
  cp $libtooldir/libbfd.a libbfd.tmp; \
  x86_64-lfs-linux-gnu-ranlib --plugin /lfs_build/tools/libexec/gcc/x86_64-lfs-linux-gnu/13.1.0/liblto_plugin.so libbfd.tmp; \
  /bin/sh ../../bfd/../move-if-change libbfd.tmp libbfd.a; \
else true; fi
touch stamp-lib
